# ============================================================
# CLERK AUTHENTICATION (Required)
# ============================================================
# Create/get a free Clerk Development instance and paste keys below.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY='pk_test_ZXhhbXBsZS5jbGVyay5hY2NvdW50cy5kZXYk'
CLERK_SECRET_KEY='sk_test_replace_me'

# ============================================================
# API INTEGRATION (Required for dashboard + uploads)
# ============================================================
NEXT_PUBLIC_API_URL='http://localhost:8787'
API_URL='http://localhost:8787'

# Shared secret used by Next.js proxy routes to sign user identity headers
# Must match INTERNAL_PROXY_SIGNING_SECRET in apps/api runtime secrets.
INTERNAL_PROXY_SIGNING_SECRET='replace_with_long_random_secret'

# Optional fallback for legacy proxy auth. Keep empty for new deployments.
API_SECRET=''

# Local-only auth bypass for OSS contributors without Clerk keys.
# Must stay 'false' outside local development.
LOCAL_DEV_AUTH_BYPASS='false'

# ============================================================
# NOTES
# ============================================================
# - Never commit .env.local with real values
# - Rotate keys immediately if they are exposed
