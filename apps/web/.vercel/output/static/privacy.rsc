sName":"mb-12","children":[["$","h2",null,{"className":"font-heading text-2xl text-text-primary mb-4","children":"1. Introduction"}],["$","p",null,{"className":"mb-4","children":"Open Mool (\"we,\" \"our,\" or \"us\") is committed to protecting the privacy of our users (\"you\" or \"Guardians\") while fulfilling our mission to preserve Himalayan cultural heritage. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you use our platform at openmool.org and related services."}],["$","p",null,{"className":"mb-4","children":"By using Open Mool, you consent to the data practices described in this policy. If you do not agree with any part of this Privacy Policy, please do not use our services."}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"font-heading text-2xl text-text-primary mb-4","children":"2. Information We Collect"}],["$","h3",null,{"className":"font-heading text-xl text-text-primary mb-3","children":"2.1 Information You Provide"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 mb-6","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Account Information:"}]," When you register via Clerk, we collect your email address, name, and authentication credentials. We do not store passwords directly."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Profile Data:"}]," Optional information you provide such as your affiliation (researcher, guardian, institution), location, and areas of cultural expertise."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Uploaded Content:"}]," Audio recordings, video files, images, documents, and associated metadata (geolocation, timestamps, cultural context, transcriptions) that you contribute to the archive."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Communications:"}]," Any messages, feedback, or correspondence you send to us."]}]]}],["$","h3",null,{"className":"font-heading text-xl text-text-primary mb-3","children":"2.2 Information Collected Automatically"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 mb-6","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Usage Data:"}]," Pages viewed, features used, search queries, and interaction patterns to improve user experience."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Device Information:"}]," Browser type, operating system, device identifiers, and IP address (anonymized where possible)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Cookies:"}]," Essential cookies for authentication and session management. We do not use advertising or tracking cookies."]}]]}],["$","h3",null,{"className":"font-heading text-xl text-text-primary mb-3","children":"2.3 Information from Third Parties"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 mb-4","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Authentication Provider (Clerk):"}]," Basic profile information from your identity provider (e.g., Google, email) when you log in."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Institutional Partners:"}]," Metadata about collections when partnering organizations bulk-upload archives."]}]]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"font-heading text-2xl text-text-primary mb-4","children":"3. How We Use Your Information"}],["$","p",null,{"className":"mb-4","children":"We use collected information to:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 mb-4","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Operate the Archive:"}]," Store, organize, transcribe (via AI), and make cultural content searchable and accessible."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Authenticate Users:"}]," Verify your identity and maintain account security."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Attribution & Karma:"}]," Credit contributors, award reputation points, and display contribution history publicly (with your consent)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"AI Processing:"}]," Use machine learning to transcribe audio, generate embeddings for semantic search, and tag content with metadata. AI processing is performed on our infrastructure or trusted processors."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Research & Analytics:"}]," Aggregate, anonymized data to understand usage patterns and improve services."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Communication:"}]," Send service updates, security alerts, and (with consent) newsletters about the project."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legal Compliance:"}]," Respond to legal requests and enforce our terms."]}]]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"font-heading text-2xl text-text-primary mb-4","children":"4. Cultural Content & Special Considerations"}],["$","p",null,{"className":"mb-4","children":"Open Mool handles culturally sensitive material. We take additional precautions:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 mb-4","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Consent of Subjects:"}]," When uploading recordings of individuals, you must have obtained appropriate consent. We encourage contributors to document consent (written or oral)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Sacred & Sensitive Content:"}]," Content marked as ceremonially sensitive or restricted may have limited access controls applied at the contributor's request."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Indigenous Data Sovereignty:"}]," We recognize the rights of Himalayan communities to their cultural heritage. The Open Mool Foundation acts as a custodian, not an owner, of cultural data."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to Removal:"}]," Community members or their representatives can request removal of content that was uploaded without proper consent or that causes harm."]}]]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"font-heading text-2xl text-text-primary mb-4","children":"5. Data Sharing & Disclosure"}],["$","p",null,{"className":"mb-4","children":"We do not sell your personal information. We may share data in the following circumstances:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 mb-4","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Public Archive:"}]," Contributed cultural content (audio, video, images, transcriptions) is made publicly accessible as part of Open Mool's mission, with attribution to contributors."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Service Providers:"}]," Trusted third parties who assist in operating our platform (e.g., Cloudflare for hosting, AI providers for transcription). These parties are bound by confidentiality agreements."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Research Partners:"}]," Anonymized or aggregated data may be shared with academic researchers for non-commercial cultural research, subject to data use agreements."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legal Requirements:"}]," When required by law, court order, or to protect the rights, safety, or property of Open Mool, users, or others."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Organizational Changes:"}]," In case of merger, acquisition, or asset sale, data may be transferred with prior notice to users."]}]]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"font-heading text-2xl text-text-primary mb-4","children":"6. Data Retention"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 mb-4","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Account Data:"}]," Retained while your account is active. Upon account deletion, personal data is removed within 30 days (except for data required for legal compliance)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Contributed Content:"}]," Cultural content is archived in perpetuity as part of our preservation mission. Contributors can request attribution changes or, under specific circumstances, removal."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Usage Logs:"}]," Anonymized and aggregated logs retained for up to 2 years for analytics purposes."]}]]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"font-heading text-2xl text-text-primary mb-4","children":"7. Data Security"}],["$","p",null,{"className":"mb-4","children":"We implement industry-standard security measures:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 mb-4","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Encryption:"}]," Data in transit is encrypted using TLS 1.3. Sensitive data at rest is encrypted using AES-256."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Access Controls:"}]," Role-based access, multi-factor authentication for administrative accounts, and regular access reviews."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Infrastructure:"}]," Hosted on Cloudflare's edge network with DDoS protection, WAF, and global redundancy."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Incident Response:"}]," Documented procedures for detecting, responding to, and notifying users of security incidents."]}]]}],["$","p",null,{"className":"mb-4","children":"While we strive to protect your information, no method of transmission or storage is 100% secure. We cannot guarantee absolute security."}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"font-heading text-2xl text-text-primary mb-4","children":"8. Your Privacy Rights"}],["$","p",null,{"className":"mb-4","children":"Depending on your jurisdiction, you may have the following rights:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 mb-4","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Access:"}]," Request a copy of personal data we hold about you."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Rectification:"}]," Correct inaccurate or incomplete personal data."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Deletion:"}]," Request deletion of your account and personal data (subject to legal retention requirements and archival exceptions for contributed content)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Portability:"}]," Receive your data in a structured, machine-readable format."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Objection:"}]," Object to certain processing activities (e.g., marketing communications)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Withdrawal of Consent:"}]," Withdraw consent where processing is based on consent."]}]]}],["$","p",null,{"className":"mb-4","children":["To exercise these rights, contact us at ",["$","a",null,{"href":"mailto:privacy@openmool.org","className":"text-primary hover:underline","children":"privacy@openmool.org"}],"."]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"font-heading text-2xl text-text-primary mb-4","children":"9. International Data Transfers"}],["$","p",null,{"className":"mb-4","children":"Open Mool operates globally. Your data may be processed in countries outside your residence, including India and the United States. We ensure appropriate safeguards are in place, such as Standard Contractual Clauses (SCCs) where required."}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"font-heading text-2xl text-text-primary mb-4","children":"10. Children's Privacy"}],["$","p",null,{"className":"mb-4","children":"Open Mool is not directed at children under 13 (or 16 in the EEA). We do not knowingly collect personal information from children. If you believe a child has provided us with personal data, please contact us, and we will delete it promptly."}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"font-heading text-2xl text-text-primary mb-4","children":"11. Third-Party Links"}],["$","p",null,{"className":"mb-4","children":"Our platform may contain links to external websites or services not operated by us. We are not responsible for the privacy practices of these third parties. We encourage you to review their privacy policies."}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"font-heading text-2xl text-text-primary mb-4","children":"12. Changes to This Policy"}],["$","p",null,{"className":"mb-4","children":"We may update this Privacy Policy periodically. Material changes will be communicated via email or a prominent notice on our website. Your continued use after changes constitutes acceptance of the updated policy."}]]}],["$","section",null,{"className":"mb-12 bg-subtle p-6 rounded-lg border border-primary/10","children":[["$","h2",null,{"className":"font-heading text-2xl text-text-primary mb-4","children":"13. Contact Us"}],["$","p",null,{"className":"mb-4","children":"For privacy-related inquiries or to exercise your rights:"}],["$","ul",null,{"className":"list-none space-y-2 mb-4","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Email:"}]," ",["$","a",null,{"href":"mailto:privacy@openmool.org","className":"text-primary hover:underline","children":"privacy@openmool.org"}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"General Contact:"}]," ",["$","a",null,{"href":"mailto:team@openmool.org","className":"text-primary hover:underline","children":"team@openmool.org"}]]}]]}],["$","p",null,{"class